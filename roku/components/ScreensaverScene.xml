<?xml version="1.0" encoding="utf-8" ?>
<!--
    ScreensaverScene  (video-globe edition)
    Smooth rotation comes from a hardware-decoded H.264 globe-spin loop
    (Video node), NOT from swapping Poster textures. Live event markers are
    projected onto the sphere in BrightScript and synced to Video.position;
    they ride inside globeCamera so a future pan/zoom keeps them aligned.

      globeCamera ........ parent group (pan/zoom target for fly-to)
        globeVideo ....... looping globe-spin video (the rotating Earth)
        markersGroup ..... one colored dot per event, projected onto the sphere
        highlightGroup ... pulsing halo over the active event
      brand .............. top-left wordmark
      statusGroup ........ top-right LIVE + count
      cardGroup .......... bottom headline card (OUTSIDE globeCamera; no zoom)
      qrOverlay .......... full-screen panel on OK/Select
-->
<component name="ScreensaverScene" extends="Scene">
    <script type="text/brightscript" uri="pkg:/components/ScreensaverScene.brs" />

    <children>

        <Group id="globeCamera" scaleRotateCenter="[960,489]">
            <Video id="globeVideo"
                   translation="[0,0]" width="1920" height="1080"
                   enableUI="false" loop="true" mute="true"
                   notificationInterval="0.1" />

            <Group id="markersGroup" />

            <Group id="highlightGroup" translation="[-800,-800]">
                <Poster id="highlightHalo"
                        uri="pkg:/images/dot.png"
                        width="116" height="116"
                        translation="[-58,-58]"
                        scaleRotateCenter="[58,58]"
                        blendColor="0x5fe3ffff"
                        opacity="0.0" />
            </Group>
        </Group>

        <!-- ===================== BRAND ===================== -->
        <Group id="brand" translation="[60,46]">
            <Label translation="[2,0]" text="REALTIME WORLD MONITOR"
                   color="0x8aa2bfff" font="font:SmallestSystemFont" />
            <Label id="brandWord" translation="[0,18]" text="GLOBAL PULSE"
                   color="0xe8f2ffff" font="font:LargeBoldSystemFont" />
        </Group>

        <!-- ===================== STATUS ===================== -->
        <Group id="statusGroup" translation="[1640,52]">
            <Rectangle id="liveDot" translation="[0,6]" width="12" height="12" color="0x43e08aff" />
            <Label id="liveTxt" translation="[22,0]" text="CONNECTING"
                   color="0xe8f2ffff" font="font:MediumBoldSystemFont" />
            <Label id="evCount" translation="[-140,30]" width="260" horizAlign="right" text=""
                   color="0x8aa2bfff" font="font:SmallSystemFont" />
        </Group>

        <!-- ===================== DETAIL PANEL (left, PC-style) ============ -->
        <Group id="detailPanel" translation="[48,112]" opacity="0.0">
            <Rectangle id="panelBg" width="704" height="906" color="0x0a1018f2" />
            <Rectangle id="accentBar" width="8" height="906" color="0x5fe3ffff" />

            <!-- hero image (with category-tinted placeholder when none) -->
            <Rectangle id="heroPlaceholder" translation="[8,0]" width="696" height="240" color="0x12203322" />
            <Label id="heroWatermark" translation="[8,96]" width="696" horizAlign="center"
                   font="font:LargeBoldSystemFont" color="0x5fe3ff44" text="" />
            <Poster id="heroImg" translation="[8,0]" width="696" height="240"
                    loadDisplayMode="scaleToZoom" />
            <Rectangle id="heroShade" translation="[8,192]" width="696" height="48" color="0x0a1018cc" />

            <Label id="categoryTag" translation="[36,278]"
                   font="font:MediumBoldSystemFont" color="0x5fe3ffff" text="" />
            <Label id="timeLabel" translation="[504,278]" width="164" horizAlign="right"
                   font="font:MediumSystemFont" color="0x8aa0b4ff" text="" />

            <!-- title fits ~4 lines; place/coords/source/blurb are repositioned
                 in code (with generous spacing) based on the headline length -->
            <Label id="titleLabel" translation="[36,326]"
                   width="632" height="184" wrap="true"
                   font="font:LargeBoldSystemFont" color="0xffffffff" text="" />

            <Label id="placeLabel" translation="[36,588]" width="632"
                   font="font:MediumBoldSystemFont" color="0x5fe3ffff" text="" />
            <Label id="coordLabel" translation="[36,626]" width="632"
                   font="font:SmallSystemFont" color="0x8aa0b4ff" text="" />
            <Label id="sourceLabel" translation="[36,656]" width="632"
                   font="font:SmallSystemFont" color="0x6f8294ff" text="" />

            <Label id="blurbLabel" translation="[36,700]"
                   width="632" height="150" wrap="true"
                   font="font:MediumSystemFont" color="0xcdd9eaff" text="" />

            <Label id="hintLabel" translation="[36,880]" width="632"
                   font="font:SmallestSystemFont" color="0x6f8294ff"
                   text="Press OK to scan QR · read full article on your phone" />
        </Group>

        <!-- ===================== QR OVERLAY ===================== -->
        <Group id="qrOverlay" opacity="0.0" visible="false">
            <Rectangle width="1920" height="1080" color="0x02040aee" />
            <Rectangle id="qrPanelBg" translation="[260,150]"
                       width="1400" height="780" color="0x0c1422ff" />
            <Rectangle id="qrAccent" translation="[260,150]"
                       width="1400" height="8" color="0x5fe3ffff" />

            <Label id="qrCategory" translation="[320,210]"
                   font="font:MediumBoldSystemFont" color="0x5fe3ffff" text="" />
            <Label id="qrTitle" translation="[320,256]"
                   width="780" height="320" wrap="true"
                   font="font:LargeBoldSystemFont" color="0xffffffff" text="" />
            <Label id="qrPlace" translation="[320,600]"
                   width="780"
                   font="font:MediumSystemFont" color="0xb9c6d6ff" text="" />
            <Label id="qrTime" translation="[320,648]"
                   width="780"
                   font="font:MediumSystemFont" color="0x8aa0b4ff" text="" />

            <Rectangle translation="[1170,250]" width="340" height="340" color="0xffffffff" />
            <Poster id="qrPoster" translation="[1190,270]"
                    width="300" height="300"
                    loadDisplayMode="scaleToFit" />

            <Label id="qrScanHint" translation="[1170,600]"
                   width="340" horizAlign="center"
                   font="font:MediumSystemFont" color="0xb9c6d6ff"
                   text="Scan to open on your phone" />
            <Label id="qrDismiss" translation="[320,820]"
                   width="1280"
                   font="font:SmallSystemFont" color="0x6f8294ff"
                   text="Press Back or Up to return to Global Pulse" />
        </Group>

        <!-- ===================== ANIMATIONS ===================== -->
        <Animation id="pulseAnim" duration="1.6" repeat="true" easeFunction="linear">
            <Vector2DFieldInterpolator
                fieldToInterp="highlightHalo.scale"
                key="[0.0,0.5,1.0]"
                keyValue="[[0.5,0.5],[1.6,1.6],[0.5,0.5]]" />
            <FloatFieldInterpolator
                fieldToInterp="highlightHalo.opacity"
                key="[0.0,0.5,1.0]"
                keyValue="[0.7,0.0,0.7]" />
        </Animation>

        <Animation id="fadeOut" duration="0.35" easeFunction="outQuad">
            <FloatFieldInterpolator
                fieldToInterp="detailPanel.opacity"
                key="[0.0,1.0]" keyValue="[1.0,0.0]" />
        </Animation>
        <Animation id="fadeIn" duration="0.5" easeFunction="outQuad">
            <FloatFieldInterpolator
                fieldToInterp="detailPanel.opacity"
                key="[0.0,1.0]" keyValue="[0.0,1.0]" />
            <Vector2DFieldInterpolator
                fieldToInterp="detailPanel.translation"
                key="[0.0,1.0]" keyValue="[[48,120],[48,112]]" />
        </Animation>

        <Animation id="qrFadeIn" duration="0.3" easeFunction="outQuad">
            <FloatFieldInterpolator
                fieldToInterp="qrOverlay.opacity"
                key="[0.0,1.0]" keyValue="[0.0,1.0]" />
        </Animation>
        <Animation id="qrFadeOut" duration="0.25" easeFunction="outQuad">
            <FloatFieldInterpolator
                fieldToInterp="qrOverlay.opacity"
                key="[0.0,1.0]" keyValue="[1.0,0.0]" />
        </Animation>

        <!-- ===================== TIMERS ===================== -->
        <Timer id="markerTick"   repeat="true" duration="0.033" />
        <Timer id="cycleTimer"   repeat="false" duration="27" />
        <Timer id="refreshTimer" repeat="true" duration="300" />

    </children>
</component>
