<?xml version="1.0" encoding="utf-8" ?>
<!--
    ScreensaverScene
    1920x1080 (fhd) screensaver scene.

      mapGroup ............ drifts a few px to avoid burn-in
        mapPoster ......... equirectangular Blue Marble base map
        markersGroup ...... one colored dot per event (built in code)
        highlightGroup .... pulsing halo over the active event
      cardGroup ........... bottom headline card (fades between events)
      qrOverlay ........... full-screen panel shown on OK/Select
-->
<component name="ScreensaverScene" extends="Scene">
    <script type="text/brightscript" uri="pkg:/components/ScreensaverScene.brs" />

    <children>

        <!-- ===================== WORLD MAP ===================== -->
        <Group id="mapGroup" translation="[0,0]">
            <!-- Map is drawn slightly oversized so the drift never
                 exposes a black gap on the left/right edges. -->
            <Poster id="mapPoster"
                    translation="[-20,50]"
                    width="1960" height="980"
                    loadDisplayMode="scaleToFill"
                    opacity="0.92" />

            <Group id="markersGroup" />

            <Group id="highlightGroup" translation="[-500,-500]">
                <Rectangle id="highlightHalo"
                           width="70" height="70"
                           translation="[-35,-35]"
                           scaleRotateCenter="[35,35]"
                           color="0x5fe3ffff"
                           opacity="0.0" />
            </Group>
        </Group>

        <!-- ===================== HEADLINE CARD ===================== -->
        <!-- Lives inside the 5% overscan-safe area (96px / 54px). -->
        <Group id="cardGroup" translation="[96,786]" opacity="0.0">
            <Rectangle id="cardBg" width="1728" height="240" color="0x0a1018e6" />
            <Rectangle id="accentBar" width="10" height="240" color="0x5fe3ffff" />

            <Label id="categoryTag" translation="[44,26]"
                   font="font:MediumBoldSystemFont" color="0x5fe3ffff" text="" />

            <Label id="titleLabel" translation="[44,72]"
                   width="1620" height="100" wrap="true"
                   font="font:LargeBoldSystemFont" color="0xffffffff" text="" />

            <Label id="placeLabel" translation="[44,186]"
                   width="1100"
                   font="font:MediumSystemFont" color="0xb9c6d6ff" text="" />

            <Label id="timeLabel" translation="[1340,186]"
                   width="344" horizAlign="right"
                   font="font:MediumSystemFont" color="0x8aa0b4ff" text="" />

            <Label id="hintLabel" translation="[44,150]"
                   width="1620"
                   font="font:SmallestSystemFont" color="0x6f8294ff"
                   text="Press OK for QR  ·  Back to return" />
        </Group>

        <!-- ===================== QR OVERLAY ===================== -->
        <Group id="qrOverlay" opacity="0.0" visible="false">
            <!-- Dim the whole screen behind the panel. -->
            <Rectangle width="1920" height="1080" color="0x02040aee" />

            <!-- Panel, overscan safe. -->
            <Rectangle id="qrPanelBg" translation="[260,150]"
                       width="1400" height="780" color="0x0c1422ff" />
            <Rectangle id="qrAccent" translation="[260,150]"
                       width="1400" height="8" color="0x5fe3ffff" />

            <Label id="qrCategory" translation="[320,210]"
                   font="font:MediumBoldSystemFont" color="0x5fe3ffff" text="" />

            <Label id="qrTitle" translation="[320,256]"
                   width="780" height="320" wrap="true"
                   font="font:LargeBoldSystemFont" color="0xffffffff" text="" />

            <Label id="qrPlace" translation="[320,600]"
                   width="780"
                   font="font:MediumSystemFont" color="0xb9c6d6ff" text="" />

            <Label id="qrTime" translation="[320,648]"
                   width="780"
                   font="font:MediumSystemFont" color="0x8aa0b4ff" text="" />

            <!-- QR image fetched from a public QR service. -->
            <Rectangle translation="[1170,250]" width="340" height="340" color="0xffffffff" />
            <Poster id="qrPoster" translation="[1190,270]"
                    width="300" height="300"
                    loadDisplayMode="scaleToFit" />

            <Label id="qrScanHint" translation="[1170,600]"
                   width="340" horizAlign="center"
                   font="font:MediumSystemFont" color="0xb9c6d6ff"
                   text="Scan to open on your phone" />

            <Label id="qrDismiss" translation="[320,820]"
                   width="1280"
                   font="font:SmallSystemFont" color="0x6f8294ff"
                   text="Press Back or Up to return to Global Pulse" />
        </Group>

        <!-- ===================== ANIMATIONS ===================== -->

        <!-- Slow map drift (burn-in protection). -->
        <Animation id="driftAnim" duration="48" repeat="true" easeFunction="linear">
            <Vector2DFieldInterpolator
                fieldToInterp="mapGroup.translation"
                key="[0.0,0.25,0.5,0.75,1.0]"
                keyValue="[[0,0],[-14,-6],[-8,-12],[-4,-4],[0,0]]" />
        </Animation>

        <!-- Continuous pulse on the active marker's halo. -->
        <Animation id="pulseAnim" duration="1.6" repeat="true" easeFunction="linear">
            <Vector2DFieldInterpolator
                fieldToInterp="highlightHalo.scale"
                key="[0.0,0.5,1.0]"
                keyValue="[[0.6,0.6],[1.7,1.7],[0.6,0.6]]" />
            <FloatFieldInterpolator
                fieldToInterp="highlightHalo.opacity"
                key="[0.0,0.5,1.0]"
                keyValue="[0.65,0.0,0.65]" />
        </Animation>

        <!-- Headline card fade out / fade-in-and-slide. -->
        <Animation id="fadeOut" duration="0.35" easeFunction="outQuad">
            <FloatFieldInterpolator
                fieldToInterp="cardGroup.opacity"
                key="[0.0,1.0]" keyValue="[1.0,0.0]" />
        </Animation>
        <Animation id="fadeIn" duration="0.5" easeFunction="outQuad">
            <FloatFieldInterpolator
                fieldToInterp="cardGroup.opacity"
                key="[0.0,1.0]" keyValue="[0.0,1.0]" />
            <Vector2DFieldInterpolator
                fieldToInterp="cardGroup.translation"
                key="[0.0,1.0]" keyValue="[[96,792],[96,760]]" />
        </Animation>

        <!-- QR overlay fade. -->
        <Animation id="qrFadeIn" duration="0.3" easeFunction="outQuad">
            <FloatFieldInterpolator
                fieldToInterp="qrOverlay.opacity"
                key="[0.0,1.0]" keyValue="[0.0,1.0]" />
        </Animation>
        <Animation id="qrFadeOut" duration="0.25" easeFunction="outQuad">
            <FloatFieldInterpolator
                fieldToInterp="qrOverlay.opacity"
                key="[0.0,1.0]" keyValue="[1.0,0.0]" />
        </Animation>

        <!-- ===================== TIMERS ===================== -->
        <Timer id="cycleTimer" repeat="true" duration="7" />
        <Timer id="refreshTimer" repeat="true" duration="300" />

    </children>
</component>
